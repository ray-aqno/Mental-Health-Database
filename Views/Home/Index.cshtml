@{
    ViewData["Title"] = "College Mental Health Resources Map";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <meta name="description" content="Midwest College Mental Health Resource Atlas connecting high school students to campus support teams.">
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Source+Sans+3:wght@400;500;600&display=swap">
    <link rel="stylesheet" href="~/css/leaflet.css" />
    <link rel="stylesheet" href="~/css/main.css" />
</head>
<body>
    <div class="app-shell" id="app-shell" data-device-mode="desktop">
        <header class="hero-panel">
            <div class="hero-content">
                <p class="hero-kicker">Midwest campus resources</p>
                <h1>Midwest College Mental Health Resource Atlas</h1>
                <p class="hero-copy">Search by campus, city, or specialty service until you find the counseling team or crisis pathway that fits your high school students. The experience adjusts between desktop and handheld automatically.</p>
                <div class="hero-command">
                    <span class="search-icon">🔍</span>
                    <input type="text"
                           id="search-input"
                           placeholder="Search colleges, cities, or services"
                           aria-label="Search colleges and resources">
                    <button class="btn btn-tertiary" id="voice-btn" aria-label="Voice search">
                        🎙 Voice
                    </button>
                </div>
                <div class="hero-actions">
                    <div class="hero-stats">
                        <div class="hero-stat">
                            <span class="hero-stat-number" id="stat-colleges">0</span>
                            <span class="hero-stat-label">Colleges</span>
                        </div>
                        <div class="hero-stat">
                            <span class="hero-stat-number" id="stat-resources">0</span>
                            <span class="hero-stat-label">Resources</span>
                        </div>
                        <div class="hero-stat">
                            <span class="hero-stat-number" id="stat-states">0</span>
                            <span class="hero-stat-label">States</span>
                        </div>
                    </div>
                    <button class="btn btn-primary" id="refresh-btn">
                        ↻ Refresh data
                    </button>
                </div>
            </div>
        </header>

        <div id="alert-container" class="alert-container"></div>

        <main class="content-grid">
            <section class="map-panel desktop-only">
                <div class="map-frame">
                    <div id="loading" class="loading">
                        <div class="spinner"></div>
                        <p>Loading colleges and resources...</p>
                    </div>
                    <div id="map"></div>
                    <div class="map-glow"></div>
                </div>
                <div class="map-overlay">
                    <div class="map-overlay-badge">Active filter: <span id="active-filter">All</span></div>
                    <div class="map-overlay-badge" id="map-pace">Search ready</div>
                </div>
                <div class="map-metadata" id="map-metadata">
                    <div class="map-metadata-heading">
                        <p class="sheet-overline">Atlas insight</p>
                        <h3>Midwest campus snapshot</h3>
                    </div>
                    <dl class="metadata-grid">
                        <div>
                            <dt>Total schools</dt>
                            <dd id="meta-colleges">0</dd>
                        </div>
                        <div>
                            <dt>Verified resources</dt>
                            <dd id="meta-resources">0</dd>
                        </div>
                        <div>
                            <dt>States represented</dt>
                            <dd id="meta-states">0</dd>
                        </div>
                    </dl>
                    <ul class="metadata-list" id="metadata-list">
                        <li>Tap or scroll to surface partner campuses near you.</li>
                    </ul>
                </div>
                <div class="floating-sheet" id="filter-sheet">
                    <div class="sheet-handle"></div>
                    <div class="sheet-header">
                        <div>
                            <p class="sheet-overline">Refine</p>
                            <h3>Filter campuses</h3>
                        </div>
                        <button class="btn btn-secondary" id="sheet-clear">Clear</button>
                    </div>
                    <div class="sheet-chips" id="filter-chip-group">
                        <button class="btn btn-chip filter-btn active" data-filter="all">All States</button>
                        <button class="btn btn-chip filter-btn" data-filter="ohio">Ohio</button>
                        <button class="btn btn-chip filter-btn" data-filter="kentucky">Kentucky</button>
                        <button class="btn btn-chip filter-btn" data-filter="indiana">Indiana</button>
                        <button class="btn btn-chip filter-btn" data-filter="illinois">Illinois</button>
                        <button class="btn btn-chip filter-btn" data-filter="michigan">Michigan</button>
                        <button class="btn btn-chip filter-btn" data-filter="pennsylvania">Pennsylvania</button>
                        <button class="btn btn-chip filter-btn" data-filter="new york">New York</button>
                    </div>
                    <div class="sheet-cta">
                        <p><strong>Crisis tips</strong></p>
                        <p class="sheet-cta-copy">Call <strong>988</strong> or text <strong>HELLO</strong> to <strong>741741</strong> whenever you need immediate support—these numbers connect you to the Suicide & Crisis Lifeline.</p>
                    </div>
                </div>
            </section>

            <section class="resource-panel desktop-only condensed">
                <div class="resource-header">
                    <div>
                        <p class="sheet-overline">Campus showcase</p>
                        <h3>Desktop research</h3>
                    </div>
                    <div class="resource-header-actions">
                        <button class="btn btn-chip" id="toggle-panel-view" aria-pressed="false">Expand list</button>
                        <span class="college-count" id="college-count">0</span>
                    </div>
                </div>
                <div class="resource-scroll">
                    <ul class="college-list" id="college-list"></ul>
                </div>
            </section>

            <section class="mobile-shell mobile-only">
                <div class="mobile-shell-header">
                    <div>
                        <p class="sheet-overline">Field guide</p>
                        <h3>Browse Midwest resources</h3>
                    </div>
                    <span class="college-count" id="college-count-mobile">0 campuses</span>
                </div>
                <div class="mobile-shell-stats">
                    <div>
                        <strong id="stat-colleges-mobile">0</strong>
                        <span>Campuses</span>
                    </div>
                    <div>
                        <strong id="stat-resources-mobile">0</strong>
                        <span>Services</span>
                    </div>
                </div>
                <div class="resource-cards" id="resource-cards"></div>
            </section>
        </main>

        <footer class="footer">
            <div>
                <p>🧭 <strong>Mental Health Resources Database</strong></p>
                <p>Helping college students find the support they need</p>
            </div>
            <div class="footer-links">
                <a href="https://github.com" target="_blank">View on GitHub</a>
                <span>•</span>
                <span>Updated for Render deployment</span>
            </div>
            <p class="footer-crisis">
                🩺 <strong>Crisis Support:</strong> Call or text <strong>988</strong> or text <strong>HELLO</strong> to <strong>741741</strong>
            </p>
        </footer>
    </div>

    <script src="~/js/leaflet.js"></script>
    <script src="~/js/app.js"></script>
</body>
</html>
